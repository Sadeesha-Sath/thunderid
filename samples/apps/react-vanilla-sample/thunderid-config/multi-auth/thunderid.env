SAMPLE_APP_CLIENT_ID=vanilla_sample_app_client
SAMPLE_APP_REDIRECT_URIS=["https://localhost:3000"]
SAMPLE_APP_GOOGLE_CLIENT_ID=<your-google-client-id>
SAMPLE_APP_GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# Must be the ThunderID server's own gate callback, not the sample app's URL,
# since Google/GitHub redirect back to whichever origin started the flow.
SAMPLE_APP_GOOGLE_REDIRECT_URI=https://localhost:8090/gate/callback # Replace with your ThunderID server's gate callback URL
SAMPLE_APP_GITHUB_CLIENT_ID=<your-github-client-id>
SAMPLE_APP_GITHUB_CLIENT_SECRET=<your-github-client-secret>
SAMPLE_APP_GITHUB_REDIRECT_URI=https://localhost:8090/gate/callback # Replace with your ThunderID server's gate callback URL
SAMPLE_APP_SMS_SENDER_ID=<your-sms-sender-id>
